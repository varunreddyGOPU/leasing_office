# Copy to .env and fill in. NEVER commit .env.
DATABASE_URL=postgresql+psycopg://auburn:auburn@localhost:5432/auburn_ridge
REDIS_URL=redis://localhost:6379/0

# Ollama Cloud (chatbot) — server-side only
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.1:70b

# News cron
NEWS_API_KEY=

# Alerts (Phase 5/6)
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Portal auth + admin (change both in production!)
SECRET_KEY=dev-secret-change-me
ADMIN_API_KEY=dev-admin

# Monitoring (optional)
SENTRY_DSN=
